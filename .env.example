# ===========================================
# LEAOZINHO - VARIÁVEIS DE AMBIENTE
# ===========================================
# Copie este arquivo para .env e preencha os valores

# ---- APP ----
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# ---- DATABASE ----
DATABASE_URL="postgresql://leaozinho:leaozinho123@localhost:5432/leaozinho_db"

# ---- REDIS ----
REDIS_URL="redis://localhost:6379"

# ---- AUTH ----
JWT_SECRET=troque_por_uma_string_secreta_longa_aqui
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=outro_segredo_para_refresh_token
JWT_REFRESH_EXPIRES_IN=7d

# ---- PIX - EFÍ (GERENCIANET) ----
EFI_CLIENT_ID=seu_client_id_efi
EFI_CLIENT_SECRET=seu_client_secret_efi
EFI_SANDBOX=true
EFI_CERT_PATH=./certs/efi-homolog.p12

# ---- AGREGADOR DE JOGOS (HUB88) ----
HUB88_API_URL=https://api.hub88.io
HUB88_OPERATOR_ID=seu_operator_id
HUB88_SECRET_KEY=seu_secret_key
HUB88_CALLBACK_URL=https://api.leaozinho.com.br/games/callback

# ---- KYC - IDWALL ----
IDWALL_API_KEY=sua_api_key_idwall
IDWALL_API_URL=https://api.idwall.co

# ---- CPF VALIDATION - SERPRO ----
SERPRO_TOKEN=seu_token_serpro
SERPRO_CPF_URL=https://gateway.apiserpro.serpro.gov.br/consulta-cpf-df/v1/cpf

# ---- SMS - TWILIO ----
TWILIO_ACCOUNT_SID=seu_account_sid
TWILIO_AUTH_TOKEN=seu_auth_token
TWILIO_FROM_NUMBER=+5511000000000

# ---- EMAIL - RESEND ----
RESEND_API_KEY=re_sua_chave_resend

# ---- ANTIFRAUDE - CLEARSALE ----
CLEARSALE_APP_KEY=sua_app_key_clearsale

# ---- NEXT.JS PUBLIC VARS ----
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=Leaozinho
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=sua_chave_recaptcha
